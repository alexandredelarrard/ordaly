# --- Secrets & local env (never commit) ---
.env
.env.*
/api/.env
!.env.example
**/local.env

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.pyo
.Python
build/
dist/
*.egg-info/
*.egg
.venv/
venv/
.envrc
.python-version

# --- Test / type / lint caches ---
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# --- App runtime: PDF inbox & volume data (keep empty dirs via .gitkeep) ---
data/
api/data/*
!api/data/.gitkeep
api/app/.log/*
!api/app/.log/.gitkeep

# Legacy local PDF folder (prefer api/data/incoming_documents in Docker)
api/incoming_documents/*
!api/incoming_documents/.gitkeep

# --- Logs (outside .log dirs) ---
*.log

# --- Editors & OS ---
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Notebooks ---
.ipynb_checkpoints/
