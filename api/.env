# Template environment file (referenced by docker-compose.yml). Copy to .env for local overrides.

LOG_LEVEL=INFO
APP_NAME=CRE Underwriting Inbound Pipeline

# In Docker Compose, override with /data (bind-mounted as ./data on the host)
DATA_ROOT=/data

# Log directory inside the container (host: ./app/.log)
LOG_DIR=/app/.log

# Optional: async SQLAlchemy (postgresql+asyncpg://user:pass@host:5432/db)
# DATABASE_URL=

# Celery / Redis (compose overrides broker for containers)
CELERY_BROKER_URL=redis://localhost:6379/0

# JWT (change in production)
JWT_SECRET_KEY='blabl!#\\bla123blablabla'
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=120

SECRET_KEY_LOGIN="J,o!Ty3qJ,o!Ty3q254"

# Comma-separated origins
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
